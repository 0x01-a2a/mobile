<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 12+ backup rules (dataExtractionRules).
  Only the explicitly listed paths are backed up — everything else is excluded
  by default when <include> elements are present, including the identity key,
  SharedPreferences, logs, and skills cache.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- ZeroClaw agent memory and chat history -->
        <include domain="file" path="zw/workspace/memory/brain.db" />
        <include domain="file" path="zw/workspace/memory/brain.db-wal" />
        <include domain="file" path="zw/workspace/memory/brain.db-shm" />
        <include domain="file" path="zw/workspace/state/memory_hygiene_state.json" />
        <include domain="file" path="zw/IDENTITY.md" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="zw/workspace/memory/brain.db" />
        <include domain="file" path="zw/workspace/memory/brain.db-wal" />
        <include domain="file" path="zw/workspace/memory/brain.db-shm" />
        <include domain="file" path="zw/workspace/state/memory_hygiene_state.json" />
    </device-transfer>
</data-extraction-rules>
