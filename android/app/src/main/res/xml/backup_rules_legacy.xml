<?xml version="1.0" encoding="utf-8"?>
<!--
  Android 6–11 backup rules (fullBackupContent).
  Only the explicitly listed paths are backed up — everything else (including
  the identity key, SharedPreferences, logs, and skills cache) is excluded
  by default when <include> elements are present.
-->
<full-backup-content>
    <include domain="file" path="zw/workspace/memory/brain.db" />
    <include domain="file" path="zw/workspace/memory/brain.db-wal" />
    <include domain="file" path="zw/workspace/memory/brain.db-shm" />
    <include domain="file" path="zw/workspace/state/memory_hygiene_state.json" />
    <include domain="file" path="zw/IDENTITY.md" />
</full-backup-content>
