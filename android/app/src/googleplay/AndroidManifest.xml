<manifest xmlns:android="http://schemas.android.com/apk/res/android"
          xmlns:tools="http://schemas.android.com/tools">

    <!-- Strip SMS — requires being default SMS app -->
    <uses-permission android:name="android.permission.READ_SMS" tools:node="remove" />
    <uses-permission android:name="android.permission.SEND_SMS" tools:node="remove" />

    <!-- Strip call log — requires carrier privilege or default dialer -->
    <uses-permission android:name="android.permission.READ_CALL_LOG" tools:node="remove" />

    <!-- Strip activity recognition — not justifiable without system app status -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" tools:node="remove" />

    <!-- Strip Bluetooth — Play Store requires prominent disclosure and narrow use case -->
    <uses-permission android:name="android.permission.BLUETOOTH" tools:node="remove" />
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" tools:node="remove" />

    <!-- Strip package usage stats — requires Special Access; Play Store disallows it -->
    <uses-permission android:name="android.permission.PACKAGE_USAGE_STATS" tools:node="remove" />

    <!-- Strip write permissions — only read-only access is justifiable on Play Store -->
    <uses-permission android:name="android.permission.WRITE_CONTACTS" tools:node="remove" />
    <uses-permission android:name="android.permission.WRITE_CALENDAR" tools:node="remove" />

    <!-- Strip phone state — not justifiable without carrier integration on Play Store -->
    <uses-permission android:name="android.permission.READ_PHONE_STATE" tools:node="remove" />

    <!-- Remove call screening service — requires being default phone app -->
    <application>
        <service android:name=".AgentCallScreeningService" tools:node="remove" />

        <!-- Remove accessibility service — Play Store policy prohibits non-accessibility uses -->
        <service android:name=".AgentAccessibilityService" tools:node="remove" />
    </application>

</manifest>
